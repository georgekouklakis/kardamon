{
    "name": "hearts-monorepo",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently -n game,api -c blue,green \"npm run dev -w packages/game-server\" \"npm run dev -w packages/platform-api\"",
        "build:kardamon": "npm run build:lib -w packages/kardamon",
        "setup": "npm install && npm run build:kardamon"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.0.0",
        "@commitlint/config-conventional": "^19.0.0",
        "concurrently": "^9.0.0",
        "husky": "^9.0.0"
    },
    "husky": {
        "hooks": {
            "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
        }
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ],
        "rules": {
            "subject-case": [
                2,
                "never",
                [
                    "start-case",
                    "pascal-case"
                ]
            ]
        }
    },
    "allowScripts": {
        "@prisma/client@5.22.0": true,
        "@prisma/engines@5.22.0": true,
        "esbuild@0.25.12": true,
        "esbuild@0.28.1": true,
        "prisma@5.22.0": true
    }
}
